{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session-register.ps1\"",
            "timeout": 15,
            "statusMessage": "Registrando sessao..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/precompact-warn.ps1\"",
            "timeout": 15,
            "statusMessage": "Sinalizando sobrecarga..."
          }
        ]
      }
    ]
  }
}
